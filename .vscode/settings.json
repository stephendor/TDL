{
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.ruff": "explicit",
    "source.organizeImports.ruff": "explicit"
  },
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true
  },
  "ruff.lint.args": ["--select=E,F,I,W"],
  "ruff.format.args": [
    "--line-length=88"
  ],
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/.vexp/daemon.pid": true,
    "**/.vexp/daemon.sock": true,
    "**/.vexp/daemon.log": true,
    "**/.vexp/vexp.log": true,
    "**/.vexp/healthy": true,
    "**/.vexp/mcp.port": true,
    "**/.vexp/index.db": true,
    "**/.vexp/index.db-wal": true,
    "**/.vexp/index.db-shm": true,
    "**/.vexp/parent_workspace.json": true,
    "**/.vexp/.gitignore": true,
    "**/.vexp/.gitattributes": true,
    "**/.vexp/daemon.pipe": true,
    "**/.vexp/mcp.token": true
  },
  "chat.tools.terminal.autoApprove": {
    "uv": true
  }
}
